{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase1 Buckling Eigen Contract Report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "contract_pass",
    "reason_code",
    "reason",
    "critical_load_factor",
    "mode_count"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "generated_at": {"type": "string"},
    "contract_pass": {"type": "boolean"},
    "reason_code": {"type": "string", "enum": ["PASS", "ERR_BUCKLING_EIGEN_INVALID"]},
    "reason": {"type": "string"},
    "critical_load_factor": {"type": "number", "exclusiveMinimum": 0},
    "mode_count": {"type": "integer", "minimum": 1},
    "selected_mode": {"type": "integer", "minimum": 1},
    "buckling_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mode_id", "eigenvalue", "normalized_shape"],
        "properties": {
          "mode_id": {"type": "integer", "minimum": 1},
          "eigenvalue": {"type": "number", "exclusiveMinimum": 0},
          "normalized_shape": {"type": "array", "minItems": 1, "items": {"type": "number"}}
        }
      }
    }
  }
}
