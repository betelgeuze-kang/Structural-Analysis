{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase1 Dynamics/Boundary Contract",
  "type": "object",
  "required": ["interface_version", "nodes", "dynamics"],
  "properties": {
    "interface_version": {"type": "string"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_id", "mass", "is_fixed_mask", "support_type", "dof_lock"],
        "properties": {
          "node_id": {"type": "string"},
          "mass": {"type": "number", "minimum": 0},
          "is_fixed_mask": {"type": "boolean"},
          "support_type": {"type": "string", "enum": ["fixed", "hinge", "roller", "free"]},
          "dof_lock": {
            "type": "object",
            "required": ["ux", "uy", "uz", "rx", "ry", "rz"],
            "properties": {
              "ux": {"type": "boolean"}, "uy": {"type": "boolean"}, "uz": {"type": "boolean"},
              "rx": {"type": "boolean"}, "ry": {"type": "boolean"}, "rz": {"type": "boolean"}
            }
          }
        }
      }
    },
    "dynamics": {
      "type": "object",
      "required": ["damping_model", "alpha_m", "beta_k", "time_step_dt", "external_force_profile"],
      "properties": {
        "damping_model": {"type": "string", "enum": ["rayleigh", "modal", "none"]},
        "alpha_m": {"type": "number", "minimum": 0},
        "beta_k": {"type": "number", "minimum": 0},
        "time_step_dt": {"type": "number", "exclusiveMinimum": 0},
        "external_force_profile": {"type": "string", "enum": ["dead", "wind", "seismic", "combined"]}
      }
    }
  }
}
