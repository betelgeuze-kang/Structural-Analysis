{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "fresh-validation-receipt.schema.v1",
  "$id": "implementation/phase1/fresh_validation_receipt.schema.json",
  "title": "Fresh full-validation lane receipt",
  "description": "Receipt recorded by a fresh full-validation lane runner. A valid receipt records a runner assertion that the lane ran on real artifacts (reused_evidence=false), captured provenance, and passed the runner contract (contract_pass=true, reason_code=PASS).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lane_id",
    "runner",
    "generated_at",
    "source_commit_sha",
    "engine_version",
    "input_checksums",
    "reused_evidence",
    "contract_pass",
    "reason_code",
    "validation_command",
    "receipt_artifacts",
    "summary",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "fresh-validation-receipt.v1"
    },
    "lane_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "runner": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "source_commit_sha": {
      "type": "string",
      "minLength": 7,
      "pattern": "^[0-9a-fA-F]{7,40}$"
    },
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "input_checksums": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[0-9a-fA-F]{64}$"
      }
    },
    "reused_evidence": {
      "type": "boolean",
      "const": false
    },
    "contract_pass": {
      "type": "boolean",
      "const": true
    },
    "reason_code": {
      "type": "string",
      "const": "PASS"
    },
    "validation_command": {
      "type": "string",
      "minLength": 1
    },
    "receipt_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$"},
          "kind": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["case_count", "passed_case_count"],
      "additionalProperties": true,
      "properties": {
        "case_count": {"type": "integer", "minimum": 0},
        "passed_case_count": {"type": "integer", "minimum": 0},
        "duration_seconds": {"type": "number", "minimum": 0}
      }
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    }
  },
  "claim_boundary": "A fresh full-validation receipt records a runner assertion that the named lane produced real, freshly-run evidence (reused_evidence=false) and that the runner's own contract checks passed (contract_pass=true, reason_code=PASS). It does not authorize Level 3 promotion, release publication, or any external claim. Promotion, claim-boundary review, and release decisions remain with the human owner."
}
